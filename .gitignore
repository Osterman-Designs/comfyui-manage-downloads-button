# Generated by setup (do not commit deploy output)
.use-pip-backend

# Local API token storage lives under ComfyUI user dir, never in repo
**/bridge-api-keys.json

# Pip-patch backup created on first optional patch run
patches/__init__.py.original

# Vendored from pip during install.py / setup (do not commit)
js/model-manager.css
js/turbogrid.esm.js
js/popover-helper.js

.gitignore
__pycache__/
*.py[cod]
*.pyo

# OS / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
